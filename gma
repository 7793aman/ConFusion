  GatewayTransaction.allow_unscoped_find
    .joins("INNER JOIN transaction_details ON (
      gateway_transactions.transaction_details_type = 'GMA::TransactionDetails'
      AND gateway_transactions.transaction_details_id = transaction_details.id
